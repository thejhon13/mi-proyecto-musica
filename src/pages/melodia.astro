---
import Layout from '../layouts/Layout.astro';

const concepto = {
  nombre: 'Melodía',

  descripcion:
    'Melodías electrónicas usando sintetizadores modernos.',

  patron:
`$: note("c4 [e4 g4] a4 g4 e4 d4")
.sound("supersaw")
.slow(2)
.gain(1.2)
.room(.4)
.delay(.25)`,

  notas: [
    'Las notas se reproducen en secuencia.',
    'La escala usa notas musicales ascendentes.',
    'El método note() define las notas.',
    'El sintetizador genera un sonido electrónico.'
  ]
};

const iframeUrl =
`https://strudel.cc/?embed=1&code=${encodeURIComponent(concepto.patron)}`;
---

<Layout title={concepto.nombre}>

  <div class="card">

    <h1>{concepto.nombre}</h1>

    <p>{concepto.descripcion}</p>

    <h2>Patrón cargado</h2>

    <pre>
      <code>{concepto.patron}</code>
    </pre>

    <h2>Descripción del patrón</h2>

    <ul>
      {concepto.notas.map(n => <li>{n}</li>)}
    </ul>

    <h2>Editor interactivo</h2>

    <p>
      Presiona Play para escuchar la melodía electrónica.
    </p>

    <iframe
      src={iframeUrl}
      title="Melodía">
    </iframe>

  </div>

</Layout>