---
import Layout from '../layouts/Layout.astro';

const concepto = {
  nombre: 'Ritmo',

  descripcion:
    'Patrones rítmicos inspirados en beats trap modernos.',

  patron:
`$: s("bd ~ [hh hh hh] ~ sn hh")
.bank("tr909")
.slow(2)
.room(.5)
.delay(.3)
.distort(.2)`,

  notas: [
    'El bombo marca el pulso principal.',
    'Los hi hats rápidos son característicos del trap.',
    'El snare agrega fuerza al ritmo.',
    'Los efectos crean una atmósfera más profunda.'
  ]
};

const iframeUrl =
`https://strudel.cc/?embed=1&code=${encodeURIComponent(concepto.patron)}`;
---

<Layout title={concepto.nombre}>

  <div class="card">

    <h1>{concepto.nombre}</h1>

    <p>{concepto.descripcion}</p>

    <h2>Patrón cargado</h2>

    <pre>
      <code>{concepto.patron}</code>
    </pre>

    <h2>Descripción del patrón</h2>

    <ul>
      {concepto.notas.map(n => <li>{n}</li>)}
    </ul>

    <h2>Editor interactivo</h2>

    <p>
      Presiona Play para escuchar el patrón rítmico.
    </p>

    <iframe
      src={iframeUrl}
      title="Ritmo">
    </iframe>

  </div>

</Layout>